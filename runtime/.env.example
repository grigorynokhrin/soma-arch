# soma runtime environment example
# Copy this file to /srv/soma/.env and adjust values for the server.
# Do not commit real .env files.

PROJECT_NAME=soma
TZ=America/Chicago

# Runtime paths
SOMA_RUNTIME_ROOT=/srv/soma
SOMA_LEGACY_ROOT=/home/grigorynokhrin/myservices
SOMA_REFERENCE_REPO=/home/grigorynokhrin/soma-arch

# HTTP ports
HTTP_PORT=80
HTTPS_PORT=443

# Gateway
SOMA_GATEWAY_CONTAINER=soma-gateway
SOMA_PORTAL_CONTAINER=soma-portal-ui

# Services
SOMA_WHISPER_SERVICE=whisper
SOMA_TESSERACT_SERVICE=tesseract
SOMA_SUPIR_SERVICE=supir

# Data roots
SOMA_DATA_ROOT=/srv/soma/data
SOMA_WHISPER_DATA=/srv/soma/data/whisper
SOMA_TESSERACT_DATA=/srv/soma/data/tesseract
SOMA_SUPIR_DATA=/srv/soma/data/supir

# Safety
SOMA_ENV=bootstrap
